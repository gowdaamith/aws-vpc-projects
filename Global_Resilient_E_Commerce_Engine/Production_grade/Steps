CLOUDFRONT CDN (content delivery network)

If we send every single request for a food image, CSS file, or React/Vue frontend asset through the Global Accelerator and into our EKS cluster, we are going to waste massive amounts of expensive compute power just serving static files.

We decouple the static frontend from the dynamic backend using CloudFront. CloudFront caches these static assets in over 400 edge locations globally. When a user in London opens CloudBite, they download the images from a server in London, not from your EKS cluster in Mumbai.
Here is the Terraform code to build the highly secure CDN layer. Create a file named cloudfront.tf.

# 1. The S3 Bucket for Static Assets (Images, Frontend UI)

# 1. The S3 Bucket for Static Assets (Images, Frontend UI)
resource "aws_s3_bucket" "cloudbite_frontend" {
  bucket = "cloudbite-production-frontend-assets"
}

# 2. Block ALL public access to the bucket
resource "aws_s3_bucket_public_access_block" "private_bucket" {
  bucket                  = aws_s3_bucket.cloudbite_frontend.id
  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

# 3. Origin Access Control (The Security Guard)
resource "aws_cloudfront_origin_access_control" "cloudbite_oac" {
  name                              = "cloudbite-frontend-oac"
  description                       = "OAC for CloudBite Frontend"
  origin_access_control_origin_type = "s3"
  signing_behavior                  = "always"
  signing_protocol                  = "sigv4"
}

# 4. The CloudFront Distribution (The Edge Cache)
resource "aws_cloudfront_distribution" "cloudbite_cdn" {
  enabled             = true
  is_ipv6_enabled     = true
  default_root_object = "index.html"
  price_class         = "PriceClass_All" # Use all global edge locations

  # Pointing to the S3 Bucket
  origin {
    domain_name              = aws_s3_bucket.cloudbite_frontend.bucket_regional_domain_name
    origin_id                = "S3-cloudbite-frontend"
    origin_access_control_id = aws_cloudfront_origin_access_control.cloudbite_oac.id
  }

  # Caching Behavior
  default_cache_behavior {
    allowed_methods  = ["GET", "HEAD", "OPTIONS"]
    cached_methods   = ["GET", "HEAD"]
    target_origin_id = "S3-cloudbite-frontend"

    viewer_protocol_policy = "redirect-to-https" # Force SSL
    compress               = true

    # Use AWS Managed Caching Policy for S3
    cache_policy_id = "658327ea-f89d-4fab-a63d-7e88639e58f6" 
  }

  viewer_certificate {
    cloudfront_default_certificate = true
    # In production, you attach your ACM Certificate here for custom domains
  }

  tags = {
    Environment = "Production"
    Project     = "CloudBite"
    Owner       = "amithkn.23ise@cambridge.edu.in"
  }
}

# 5. The Bucket Policy (Allowing CloudFront to actually read the files)
resource "aws_s3_bucket_policy" "allow_cloudfront" {
  bucket = aws_s3_bucket.cloudbite_frontend.id
  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "AllowCloudFrontServicePrincipal"
        Effect    = "Allow"
        Principal = { Service = "cloudfront.amazonaws.com" }
        Action    = "s3:GetObject"
        Resource  = "${aws_s3_bucket.cloudbite_frontend.arn}/*"
        Condition = {
          StringEquals = {
            "AWS:SourceArn" = aws_cloudfront_distribution.cloudbite_cdn.arn
          }
        }
      }
    ]
  })
}




